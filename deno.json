{
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any", "ban-types"]
    }
  },
  "permissions": {
    "commitlint": {
      "env": true,
      "read": true,
      "run": ["git"],
      "sys": ["homedir"]
    },
    "hook": {
      "read": ["./.git"],
      "run": ["git"],
      "write": ["./hooks"]
    },
    "test": {
      "env": true,
      "net": ["0.0.0.0", "127.0.0.1", "localhost"],
      "read": true,
      "sys": ["hostname"],
      "write": true
    }
  },
  "tasks": {
    "check": "deno check --frozen packages/**/src",
    "commitlint": "deno run --permission-set=commitlint @commitlint/cli",
    "hook": "deno run --permission-set=hook https://deno.land/x/deno_hooks@0.1.1/mod.ts",
    "test": "deno test --frozen --permission-set=test packages/**/test",
    "test:dev": "deno test --permission-set=test packages/**/test"
  },
  "workspace": [
    "./packages/*"
  ],
  "imports": {
    "@commitlint/cli": "npm:@commitlint/cli@^20.5.0",
    "@commitlint/config-conventional": "npm:@commitlint/config-conventional@^20.5.0",
    "lint-staged": "npm:lint-staged@^16.4.0",
    "utility-types": "npm:utility-types@^3.11.0"
  }
}
