{
  "name": "@targetd/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "check": "tsc --build --noEmit",
    "commitlint": "commitlint",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "husky",
    "start": "tsc --build --watch --preserveWatchOutput",
    "test": "bun test packages/**/test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "catalog:"
  },
  "catalog": {
    "@types/bun": "^1.3.10",
    "@types/sinon": "^21.0.0",
    "es-toolkit": "^1.45.1",
    "sinon": "^21.0.3",
    "ts-toolbelt": "^9.6.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
